# Clara AI Monorepo — Environment Template
# Instructions: Copy this file to .env and fill in the values.
# Never commit the .env file to the repository.

# ── AI Engine ──────────────────────────────
# URL of the Ollama service (internal Docker network name)
OLLAMA_BASE_URL=http://ollama:11434
# Local LLM model to use (llama3.2:1b is optimized for CPU inference)
OLLAMA_MODEL=llama3.1:8b         # production-grade model for Clara

# ── Database ───────────────────────────────
# Connection details from supabase.com > project settings > API
SUPABASE_URL=                    
# Public anon key (safe for frontend)
SUPABASE_ANON_KEY=               
# Secret service role key (backend only, NEVER expose to frontend)
SUPABASE_SERVICE_KEY=            

# ── Redis ──────────────────────────────────
# Connection string for the internal Redis service
REDIS_URL=redis://:password@redis:6379/0
# Choose a strong password for the Redis instance
REDIS_PASSWORD=                  

# ── Auth ───────────────────────────────────
# Secret key for JWT signing (generate: openssl rand -hex 32)
JWT_SECRET=                      
# Signature algorithm (HS256)
JWT_ALGORITHM=HS256
# Token expiration time (8 hours = 480 minutes)
JWT_EXPIRY_MINUTES=480

# ── Alerting ───────────────────────────────
# Firebase Cloud Messaging key for push notifications
FCM_SERVER_KEY=                  
# Resend API key for transactional emails
RESEND_API_KEY=                  
# Sender and receiver email addresses for alerts
ALERT_EMAIL_FROM=alerts@yourdomain.com
ALERT_EMAIL_TO=caregiver@yourdomain.com

# ── Observability ──────────────────────────
# Sentry DSN for backend error tracking
SENTRY_DSN_BACKEND=              
# Separate Sentry DSN for frontend (Next.js) tracking
SENTRY_DSN_FRONTEND=             
# Environment name (development | staging | production)
ENVIRONMENT=development          
